!output/xenium_vs_merfish_scatter.png
!output/xenium_corr_control_vs_merfish_validation.png
!output/depth_proportions/*.png
output/**/*.pptx
output/**/*.pdf

# Archived presentation files (stale exploration outputs)
output/presentation/_archived/

# Empty/unused output dirs
output/nsforest/
output/sccoda/
output/figures/

